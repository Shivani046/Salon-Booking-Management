generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String
  password String

  @@map("admin")
}

model Customer {
  custId       Int           @id @default(autoincrement())   // ✅ renamed field
  name         String
  phoneNo      String        @unique
  emailId      String        @unique
  password     String
  role         String        @default("user")
  appointments Appointment[]
  payments     Payment[]

  @@map("customer")
}

model Staff {
  staffId      Int            @id @default(autoincrement())  // ✅ renamed field
  name         String
  staffServices StaffService[]

  @@map("staff")
}

model Service {
  serviceId    Int            @id @default(autoincrement())  // ✅ renamed field
  type         String         @unique
  category     String?
  price        Int
  staffServices StaffService[]

  @@map("service")
}

model Payment {
  id            Int    @id @default(autoincrement())
  customerId    Int
  appointmentId Int
  method        String
  amount        Int

  appointment Appointment @relation(fields: [appointmentId], references: [appId], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [custId], onDelete: Cascade)

  @@index([customerId])
  @@index([appointmentId])
  @@map("payment")
}

model StaffService {
  serviceId Int
  staffId   Int
  service   Service @relation(fields: [serviceId], references: [serviceId], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [staffId], onDelete: Cascade)

  @@id([serviceId, staffId], map: "_StaffServices_AB_pkey")
  @@index([staffId], map: "_StaffServices_B_index")
  @@map("_StaffServices")
}

model Appointment {
  appId      Int      @id @default(autoincrement())          // ✅ renamed field
  customerId Int      @map("custId")
  service    String
  staff      String
  appDate    DateTime
  appTime    String
  status     String
  amount     Int

  customer Customer  @relation(fields: [customerId], references: [custId])
  payments Payment[]

  @@map("appointments")
}

