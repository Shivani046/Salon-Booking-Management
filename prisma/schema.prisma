generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  adminId  Int    @id @default(autoincrement())
  username String
  password String

  @@map("admin")
}

model Customer {
  custId       Int           @id @default(autoincrement())
  name         String
  phoneNo      String        @unique
  emailId      String        @unique
  password     String
  appointments Appointment[]
  payments     Payment[]

  @@map("customer")
}

model Appointment {
  appId    Int       @id @default(autoincrement())
  custId   Int
  service  String
  staff    String?
  appDate  DateTime
  appTime  String
  amount   String?
  status   String    @default("scheduled")
  customer Customer  @relation(fields: [custId], references: [custId], onDelete: Cascade)
  payments Payment[]

  @@index([custId])
  @@index([appDate])
  @@map("appointment")
}

model Staff {
  staffId  Int       @id @default(autoincrement())
  name     String
  services Service[] @relation("StaffServices")

  @@map("staff")
}

model Service {
  serviceId Int     @id @default(autoincrement())
  type      String  @unique
  category  String?
  staff     Staff[] @relation("StaffServices")

  @@map("service")
}

model Payment {
  payId       Int         @id @default(autoincrement())
  custId      Int
  appId       Int
  method      String
  appointment Appointment @relation(fields: [appId], references: [appId], onDelete: Cascade)
  customer    Customer    @relation(fields: [custId], references: [custId], onDelete: Cascade)

  @@index([custId])
  @@index([appId])
  @@map("payment")
}
