generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  adminId  Int    @id @default(autoincrement())
  username String
  password String

  @@map("admin")
}

model Customer {
  custId       Int            @id @default(autoincrement())
  name         String
  phoneNo      String         @unique
  emailId      String         @unique
  password     String
  role         String         @default("user")
  appointments appointments[]
  payments     Payment[]

  @@map("customer")
}

model Staff {
  staffId       Int             @id @default(autoincrement())
  name          String
  StaffServices StaffServices[]

  @@map("staff")
}

model Service {
  serviceId     Int             @id @default(autoincrement())
  type          String          @unique
  category      String?
  price         Int
  StaffServices StaffServices[]

  @@map("service")
}

model Payment {
  payId       Int          @id @default(autoincrement())
  custId      Int
  appId       Int
  method      String
  amount      Int
  appointment appointments @relation(fields: [appId], references: [appId], onDelete: Cascade)
  customer    Customer     @relation(fields: [custId], references: [custId], onDelete: Cascade)

  @@index([custId])
  @@index([appId])
  @@map("payment")
}

model StaffServices {
  serviceId Int
  staffId   Int
  service   Service @relation(fields: [serviceId], references: [serviceId], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [staffId], onDelete: Cascade)

  @@id([serviceId, staffId], map: "_StaffServices_AB_pkey")
  @@index([staffId], map: "_StaffServices_B_index")
  @@map("_StaffServices")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model appointments {
  appId    Int       @id(map: "appointment_pkey") @default(autoincrement())
  custId   Int
  service  String
  staff    String
  appDate  DateTime
  appTime  String
  status   String
  amount   Int
  customer Customer  @relation(fields: [custId], references: [custId], map: "appointment_custId_fkey")
  payments Payment[]
}
