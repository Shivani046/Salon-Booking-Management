generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String
  password String

  @@map("admin")
}

model Customer {
  id           Int          @id @default(autoincrement())
  name         String
  phoneNo      String       @unique
  emailId      String       @unique
  password     String
  role         String       @default("user")
  appointments Appointment[]
  payments     Payment[]

  @@map("customer")
}

model Staff {
  id            Int            @id @default(autoincrement())
  name          String
  staffServices StaffService[]

  @@map("staff")
}

model Service {
  id            Int            @id @default(autoincrement())
  type          String         @unique
  category      String?
  price         Int
  staffServices StaffService[]

  @@map("service")
}

model Payment {
  id          Int         @id @default(autoincrement())
  customerId  Int
  appointmentId Int
  method      String
  amount      Int
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([appointmentId])
  @@map("payment")
}

model StaffService {
  serviceId Int
  staffId   Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([serviceId, staffId], map: "_StaffServices_AB_pkey")
  @@index([staffId], map: "_StaffServices_B_index")
  @@map("_StaffServices")
}

model Appointment {
  id       Int       @id @default(autoincrement())
  customerId Int
  service  String
  staff    String
  appDate  DateTime
  appTime  String
  status   String
  amount   Int
  customer Customer  @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@map("appointments")
}

