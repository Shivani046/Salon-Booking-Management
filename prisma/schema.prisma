datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  custId   Int    @id @default(autoincrement())
  name     String
  password String
  phoneNo  String
  emailId  String @unique
  role     String @default("user")

  // opposite sides of relations
  appointments Appointment[]
  payments     Payment[]
}

model Appointment {
  appId      Int      @id @default(autoincrement())
  customerId Int
  serviceId  Int
  staffId    Int
  appDate    DateTime
  appTime    String
  status     String
  amount     Float

  // relations
  customer Customer  @relation(fields: [customerId], references: [custId])
  service  Service   @relation(fields: [serviceId], references: [serviceId])
  staff    Staff     @relation(fields: [staffId], references: [staffId])
  payments Payment[]
}

model Service {
  serviceId Int    @id @default(autoincrement())
  type      String
  category  String
  price     Float

  appointments Appointment[]
  staff        StaffService[] // ✅ many-to-many join
}

model Staff {
  staffId Int    @id @default(autoincrement())
  name    String

  appointments Appointment[]
  services     StaffService[] // ✅ many-to-many join
}

// ✅ join table for many-to-many Staff <-> Service
model StaffService {
  staffId   Int
  serviceId Int

  staff   Staff   @relation(fields: [staffId], references: [staffId])
  service Service @relation(fields: [serviceId], references: [serviceId])

  @@id([staffId, serviceId])
}

model Payment {
  id            Int    @id @default(autoincrement())
  appointmentId Int
  customerId    Int
  method        String
  amount        Float

  appointment Appointment @relation(fields: [appointmentId], references: [appId], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [custId], onDelete: Cascade)
}
